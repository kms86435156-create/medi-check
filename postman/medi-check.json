{
	"info": {
		"name": "MediCheck API",
		"description": "강남/신논현 피부과 AI 리뷰 분석 플랫폼 API 컬렉션",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Root",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/",
					"host": ["{{base_url}}"],
					"path": [""]
				}
			}
		},
		{
			"name": "Hospitals",
			"item": [
				{
					"name": "병원 목록 조회",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/hospitals?page=1&size=20&sort=id",
							"host": ["{{base_url}}"],
							"path": ["api", "hospitals"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "size", "value": "20" },
								{ "key": "sort", "value": "id" },
								{ "key": "search", "value": "", "disabled": true }
							]
						}
					}
				},
				{
					"name": "병원 상세 조회",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/hospitals/1",
							"host": ["{{base_url}}"],
							"path": ["api", "hospitals", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Reviews",
			"item": [
				{
					"name": "병원 리뷰 조회",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/reviews/1",
							"host": ["{{base_url}}"],
							"path": ["api", "reviews", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Search (LBS)",
			"item": [
				{
					"name": "근처 병원 검색 (거리순)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/search?lat=37.504&lng=127.024&radius=5&sort=distance",
							"host": ["{{base_url}}"],
							"path": ["api", "search"],
							"query": [
								{ "key": "lat", "value": "37.504", "description": "사용자 위도 (강남역 기준)" },
								{ "key": "lng", "value": "127.024", "description": "사용자 경도" },
								{ "key": "radius", "value": "5", "description": "반경 (km)" },
								{ "key": "sort", "value": "distance", "description": "정렬: distance | ai_score" }
							]
						}
					}
				},
				{
					"name": "근처 병원 검색 (AI 평점순)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/search?lat=37.504&lng=127.024&radius=5&sort=ai_score",
							"host": ["{{base_url}}"],
							"path": ["api", "search"],
							"query": [
								{ "key": "lat", "value": "37.504", "description": "사용자 위도 (강남역 기준)" },
								{ "key": "lng", "value": "127.024", "description": "사용자 경도" },
								{ "key": "radius", "value": "5", "description": "반경 (km)" },
								{ "key": "sort", "value": "ai_score", "description": "AI 평점 내림차순" }
							]
						}
					}
				},
				{
					"name": "근처 병원 검색 (반경 1km)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/search?lat=37.504&lng=127.024&radius=1&sort=distance",
							"host": ["{{base_url}}"],
							"path": ["api", "search"],
							"query": [
								{ "key": "lat", "value": "37.504" },
								{ "key": "lng", "value": "127.024" },
								{ "key": "radius", "value": "1", "description": "좁은 반경 테스트" },
								{ "key": "sort", "value": "distance" }
							]
						}
					}
				}
			]
		}
	]
}
